# Telegram bot token from @BotFather
BOT_TOKEN=

# ID of the group chat (negative number; for supergroups starts with -100...)
GROUP_CHAT_ID=

# Admin telegram username WITHOUT the @ — will be pinged on full check failure
ADMIN_USERNAME=

# Random long string. Used as Telegram webhook secret_token.
WEBHOOK_SECRET=

# Random long string. Used to protect /api/cron and /api/setup.
CRON_SECRET=

# Vercel KV / Upstash Redis. Vercel sets these automatically when the KV
# integration is attached to the project. The code supports both legacy
# (KV_REST_API_*) and current (UPSTASH_REDIS_REST_*) names.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
